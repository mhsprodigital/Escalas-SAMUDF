rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // ===============================================================
    // Assumed Data Model
    // ===============================================================
    //
    // Collection: employees
    // Fields: id, name, matricula, coren, role, contractHours, unit, sector, cnes, contact, restrictions, colorIdentifier, preferences
    //
    // Collection: assignments
    // Fields: id, employeeId, date, shiftCode, duration, isManualLock
    //
    // Collection: settings
    // Fields: id, units, hours, rulesTitle, rulesDesc, glossary, shiftDefs
    //
    // ===============================================================

    // Helper Functions
    function isAuthenticated() {
      return request.auth != null;
    }

    function isMaster() {
      return isAuthenticated() && request.auth.token.email.lower() == "mhs.pro.digital@gmail.com";
    }

    function getRole() {
      let userDoc = /databases/$(database)/documents/system_users/$(request.auth.token.email.lower());
      return exists(userDoc) ? get(userDoc).data.role : 'VIEWER';
    }

    function isAdmin() {
      return isMaster() || (isAuthenticated() && getRole() == 'ADMIN');
    }

    function canEdit() {
      let role = getRole();
      return isMaster() || (isAuthenticated() && (role == 'ADMIN' || role == 'EDITOR'));
    }

    // Validation Helpers
    function isValidEmployee(data) {
      return data.keys().hasAll(['id', 'name', 'matricula', 'role']) &&
             data.name is string && data.name.size() > 0 && data.name.size() < 100 &&
             data.matricula is string && data.matricula.size() > 0 && data.matricula.size() < 20;
    }

    function isValidAssignment(data) {
      return data.keys().hasAll(['id', 'employeeId', 'date', 'shiftCode']) &&
             data.employeeId is string && data.date is string && data.shiftCode is string;
    }

    function isValidSystemUser(data) {
      return data.keys().hasAll(['email', 'role', 'displayName']) &&
             data.email is string && data.email.size() < 100 &&
             data.role in ['ADMIN', 'EDITOR', 'VIEWER'] &&
             data.displayName is string && data.displayName.size() < 100;
    }

    match /system_users/{userId} {
      allow read: if isAuthenticated();
      allow create, update: if isAdmin() && isValidSystemUser(request.resource.data);
      allow delete: if isAdmin();
    }

    match /employees/{employeeId} {
      allow read: if isAuthenticated();
      allow create, update: if canEdit() && isValidEmployee(request.resource.data);
      allow delete: if canEdit();
    }

    match /assignments/{assignmentId} {
      allow read: if isAuthenticated();
      allow create, update: if canEdit() && isValidAssignment(request.resource.data);
      allow delete: if canEdit();
    }

    match /settings/{settingId} {
      allow read: if isAuthenticated();
      allow write: if isAdmin();
    }

    match /vehicles/{vehicleId} {
      allow read: if isAuthenticated();
      allow write: if isAdmin();
    }

    match /sectors/{sectorId} {
      allow read: if isAuthenticated();
      allow write: if isAdmin();
    }
  }
}
